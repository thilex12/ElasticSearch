{
  "settings": {
    "analysis": {
      "filter": {
        "french_stemmer": {
          "type": "stemmer",
          "language": "light_french"
        }
      },
      "analyzer": {
        "french_simple": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "asciifolding",
            "french_stemmer"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": { "type": "keyword" },

      "nom": {
        "type": "search_as_you_type",
        "analyzer": "french_simple"
      },

      "description": {
        "type": "search_as_you_type",
        "analyzer": "french_simple"
      },

      "marque": {
        "type": "search_as_you_type",
        "analyzer": "french_simple",
        "fields": {
          "keyword": { "type": "keyword" }
        }
      },

      "categories": {
        "type": "search_as_you_type",
        "analyzer": "french_simple",
        "fields": {
          "keyword": { "type": "keyword" }
        }
      },

      "tags": {
        "type": "search_as_you_type",
        "analyzer": "french_simple",
        "fields": {
          "keyword": { "type": "keyword" }
        }
      },

      "prix": {
        "properties": {
          "valeur": { "type": "float" },
          "devise": { "type": "keyword" },
          "prix_promotionnel": { "type": "float" },
          "promotion_actif": { "type": "boolean" }
        }
      },

      "disponibilite": {
        "properties": {
          "en_stock": { "type": "boolean" },
          "quantite": { "type": "integer" },
          "delai_livraison": { "type": "keyword" }
        }
      },

      "evaluations": {
        "properties": {
          "note_moyenne": { "type": "float" },
          "nombre_avis": { "type": "integer" }
        }
      },

      "caracteristiques": {
      "properties": {
        "couleur": {
          "type": "search_as_you_type",
          "analyzer": "french_simple",
          "fields": { "keyword": { "type": "keyword" } }
        },
        "materiaux": {
          "type": "search_as_you_type",
          "analyzer": "french_simple",
          "fields": { "keyword": { "type": "keyword" } }
        }
      }
    },

      "images": { "type": "keyword" },

      "date_ajout": { "type": "date" },
      "date_mise_a_jour": { "type": "date" }
    }
  }
}
